# URL base de la API del backend (desarrollo local)
# Perfil "http" del backend: http://localhost:5053
# Si usas HTTPS, pon la URL https completa (evita mezclar http con redirects que quiten el Bearer token).
REACT_APP_API_BASE_URL=http://localhost:5053

# Opcional: si usas Cloudinary desde el frontend
# REACT_APP_CLOUDINARY_CLOUD_NAME=tu_cloud_name
# REACT_APP_CLOUDINARY_API_KEY=tu_api_key
